{
  "svelte.enable-ts-plugin": true,
  "chat.tools.terminal.autoApprove": {
    "cargo fmt": true,
    "cargo clippy": true,
    "cargo test": true,
    "cargo check": true,
    "git add": true,
    "git commit": true,
    "npm": true
  },
  "files.watcherExclude": {
    ".git/objects/**": true,
    ".git/subtree-cache/**": true,
    ".hg/store/**": true,
    "*/.git/objects/**": true,
    "*/.git/subtree-cache/**": true,
    "*/.hg/store/**": true,
    "**/node_modules/**": true,
    "**/.flatpak-builder/**": true,
    "**/__pycache__/**": true,
    "**/.venv/**": true,
    "**/dist/**": true,
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/.hg/store/**": true,
    ".flatpak/**": true,
    "_build/**": true
  },
  "rust-analyzer.server.path": "${workspaceFolder}/.flatpak/rust-analyzer.sh"
}
