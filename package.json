{
  "name": "ronmodmanager",
  "version": "0.1.0",
  "description": "Cross-platform Ready or Not mod manager built with Tauri and Svelte",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "dev:linux": "WEBKIT_DISABLE_DMABUF_RENDERER=1 LIBGL_ALWAYS_SOFTWARE=1 pnpm tauri dev",
    "dev:xwayland": "GDK_BACKEND=x11 pnpm tauri dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check .",
    "format": "prettier --write .",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "tauri": "tauri",
    "prepare": "husky",
    "release": "dotenvx run -- pnpm tauri build"
  },
  "license": "MIT",
  "dependencies": {
    "@dotenvx/dotenvx": "^1.65.1",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2",
    "adwavecss": "^0.2.6",
    "adwaveui": "^0.3.2",
    "lucide-svelte": "^1.0.1"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.59.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/cli": "^2",
    "@testing-library/svelte": "^5.3.1",
    "@vitest/coverage-v8": "^4.1.6",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.4",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.2",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.8",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.3",
    "vite": "^8.0.12",
    "vitest": "^4.1.6"
  },
  "lint-staged": {
    "*.{js,ts,svelte}": [
      "prettier --write"
    ],
    "*.{css,json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
