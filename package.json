{
  "name": "ronmodmanager",
  "version": "0.1.0",
  "description": "Cross-platform Ready or Not mod manager built with Tauri and Svelte",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "dev:linux": "WEBKIT_DISABLE_DMABUF_RENDERER=1 LIBGL_ALWAYS_SOFTWARE=1 pnpm tauri dev",
    "dev:xwayland": "GDK_BACKEND=x11 pnpm tauri dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check .",
    "format": "prettier --write .",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "tauri": "tauri",
    "prepare": "husky",
    "release": "dotenvx run -- pnpm tauri build"
  },
  "license": "MIT",
  "dependencies": {
    "@dotenvx/dotenvx": "^1.54.1",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "adwavecss": "^0.2.6",
    "adwaveui": "^0.3.0",
    "lucide-svelte": "^0.577.0"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.9.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tailwindcss/vite": "^4.2.1",
    "@tauri-apps/cli": "^2",
    "@testing-library/svelte": "^5.3.1",
    "@vitest/coverage-v8": "^4.0.18",
    "husky": "^9.1.7",
    "jsdom": "^29.0.0",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "*.{js,ts,svelte}": [
      "prettier --write"
    ],
    "*.{css,json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
