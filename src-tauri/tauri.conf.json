{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RoN Mod Manager",
  "version": "0.0.0",
  "identifier": "uk.savagecore.ronmodmanager",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "RoN Mod Manager",
        "width": 1280,
        "height": 840,
        "minWidth": 1024,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["msi", "nsis", "deb", "appimage", "rpm"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDFDQjczODFDNUI0RDJFNDEKUldSQkxrMWJIRGkzSExNWmRxZ04xQ3lyd3NHQXF0SGxja0E0S0xGQUNoQnV0VHpkd1FpSGJSRGMK",
      "endpoints": [
        "https://github.com/savagecore/RoNModManager/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
